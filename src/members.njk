---
layout: wide-page.njk
title: Information for Members
description: Rehearsal location and schedules for the Amherst Community Band.
---
<div class="columns">
    <div class="column is-one-half is-offset-1">
        <div class="container pl-6">
            <section>
                <div class="container">
                    <h3 class="title is-3 mb-1">Where</h3>
                        <p>Parks Band Building<br>110 Grinnell Road<br>Amherst, MA 01003<br>
                        <a href="https://www.google.com/maps/search/?api=1&query=Parks+Band+Building,+110+Grinnell+Road,+Amherst,+MA+01003" target="_blank" rel="noopener noreferrer">Google Maps</a>
                        <br>
                        <a href="{{ '/locations/' | withBase }}">View Locations &amp; Directions</a>
                        <br>
                        <i>(unless noted otherwise)</i></p>
                </div>
            </section>
            <section>
                <div class="container mt-3">
                    <h3 class="title is-3 mb-2">When</h3>
                    {% for category in config.rehearsals %}
                        <h5 class="title is-5 mb-1">{{ category.label }}</h5>
                            <ul>
                            {% for rehearsal in category.schedule_items %}
                                {% if rehearsal.location %}
                                    <li>{{ rehearsal.date_and_time }} <b>{{ rehearsal.location }}</b></li>
                                {% else %}
                                    <li>{{ rehearsal.date_and_time }}</li>
                                {% endif %}
                            {% endfor %}
                            </ul>
                    {% endfor %}
                </div>
            </section>
        </div>
    </div>
    <div class="column is-one-half is-vcentered">
        <figure class="has-soft-corners image is-4by3">
            <iframe class="has-ratio" src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FNew_York&showPrint=0&src=YjQyODdmY2QwZDA5YjgzN2I1MTFiZDBjODU3ZWMzOTg0NTYxNmQ1MTFkODE2MTAzY2JiMTYwMDRiM2E3Mjg5MUBncm91cC5jYWxlbmRhci5nb29nbGUuY29t&color=%23e67c73" style="border:solid 1px #777" width="800" height="600" frameborder="0" scrolling="no"></iframe>
        </figure>
    </div>
</div>
