---
layout: page.njk
---
<section class="section">
    <div class="container acb-regular-page">
        <h1 class="title is-1 has-text-centered mb-4">{{ title }}</h1>
        {% if intro %}
            <p class="acb-regular-intro subtitle is-5 has-text-centered mb-5">{{ intro }}</p>
        {% endif %}
        <div class="columns is-variable is-6 acb-regular-layout">
            <div class="column is-two-thirds acb-regular-main">
                {{ content | safe }}
            </div>
            {% if sidebarTitle or sidebarLinks or sidebarText %}
                <aside class="column is-one-third acb-regular-sidebar" aria-label="Page sidebar">
                    <div class="acb-sidebar-box">
                        {% if sidebarTitle %}
                            <h2 class="title is-4 mb-3">{{ sidebarTitle }}</h2>
                        {% endif %}
                        {% if sidebarText %}
                            <p class="mb-3">{{ sidebarText }}</p>
                        {% endif %}
                        {% if sidebarLinks %}
                            <ul class="acb-sidebar-list">
                                {% for link in sidebarLinks %}
                                    <li>
                                        <a href="{{ link.href | withBase }}">{{ link.text }}</a>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </div>
                </aside>
            {% endif %}
        </div>
    </div>
</section>
