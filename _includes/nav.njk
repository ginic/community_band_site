<section class="p-0">
<nav class="navbar is-primary" role="navigation" aria-label="main navigation">
    <div class="container">
        <div class="navbar-brand">
            {% image "src" + config.logoUrl, config.title, "180px" %}
            <a role="button" class="navbar-burger" data-target="navigation-headers" aria-label="menu" aria-expanded="false">
                <span aria-hidden="true"></span>
                <span aria-hidden="true"></span>
                <span aria-hidden="true"></span>
                <span aria-hidden="true"></span>
            </a>
        </div>

        <div id="navigation-headers" class="navbar-menu">
            <div class="navbar-start">
                {% for item in config.navbarMenu %}
                    <a class="navbar-item" href="{{item.url}}">
                        {{item.anchor}}
                    </a>
                {% endfor %}
            </div>
        </div>
    </div>
</nav>
</section>